{
  "manifest_version": 3,
  "name": "Pet Companion",
  "version": "1.0.0",
  "description": "A cute pixel-art pet — cat or owl — that walks across your pages, reacts to clicks, and grows as you play.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Pet Companion",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "permissions": ["storage", "alarms"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/lib/raster.js",
        "src/lib/critters.js",
        "src/lib/spritecat.js",
        "src/lib/storage.js",
        "src/lib/pet.js",
        "src/content/content.js"
      ],
      "css": ["src/content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/assets/cat/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
